#!/bin/bash

if type update-alternatives 2>/dev/null >&1; then
    # Remove previous link if it doesn't use update-alternatives
    if [ -L '/usr/bin/perzike' -a -e '/usr/bin/perzike' -a "`readlink '/usr/bin/perzike'`" != '/etc/alternatives/perzike' ]; then
        rm -f '/usr/bin/perzike'
    fi
    update-alternatives --install '/usr/bin/perzike' 'perzike' '/opt/perzike/perzike' 100 || ln -sf '/opt/perzike/perzike' '/usr/bin/perzike'
else
    ln -sf '/opt/perzike/perzike' '/usr/bin/perzike'
fi

sed -i 's/Name=perzike/Name=Perzike/' '/usr/share/applications/perzike.desktop'

chmod 4755 '/opt/perzike/chrome-sandbox' || true
chmod +sx /opt/perzike/resources/sidecar/mihomo
chmod +sx /opt/perzike/resources/sidecar/mihomo-alpha

if [ -d '/opt/perzike/resources/files/sub-store-frontend' ]; then
    chmod -R go-w '/opt/perzike/resources/files/sub-store-frontend' 2>/dev/null || true
fi

if hash update-mime-database 2>/dev/null; then
    update-mime-database /usr/share/mime || true
fi

if hash update-desktop-database 2>/dev/null; then
    update-desktop-database /usr/share/applications || true
fi
